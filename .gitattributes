# Handle line endings consistently across platforms
* text=auto eol=lf

# Java source files
*.java text eol=lf
*.xml  text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.json text eol=lf
*.properties text eol=lf

# Windows shell scripts keep their endings
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary files — never diff or merge
*.jar  binary
*.png  binary
*.jpg  binary
*.gif  binary
